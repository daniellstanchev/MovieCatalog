@model MoviesCatalog.Models.Director

@{
    ViewData["Title"] = "Edit Director";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card border-0 shadow-lg" style="border-radius: 30px;">
                    <div class="card-header bg-transparent border-0 text-center pt-5">
                        <i class="bi bi-pencil-square display-1 text-warning"></i>
                        <h2 class="mt-3 fw-bold">Edit Director</h2>
                    </div>
                    <div class="card-body p-5">
                        <form asp-action="Edit">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <input type="hidden" asp-for="Id" />

                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-bold">Full Name</label>
                                <input asp-for="Name" class="form-control form-control-lg rounded-pill shadow-sm" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Country" class="form-label fw-bold">Country</label>
                                <input asp-for="Country" class="form-control form-control-lg rounded-pill shadow-sm" />
                                <span asp-validation-for="Country" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Select Movies by this Director</label>
                                <select name="selectedMovieIds" class="form-select shadow-sm" multiple size="8" style="border-radius: 15px;">
                                    @foreach (var movie in ViewBag.Movies)
                                    {
                                        var isSelected = ViewBag.SelectedMovieIds != null && ((List<int>)ViewBag.SelectedMovieIds).Contains(movie.Id);
                                            <option value="@movie.Id" selected="@isSelected">@movie.Title (@movie.ReleaseYear)</option>
                                    }
                                </select>
                                <small class="text-muted">Hold Ctrl (or Cmd on Mac) to select multiple movies</small>
                            </div>

                            <div class="d-flex gap-3 mt-4">
                                <button type="submit" class="btn btn-warning btn-lg rounded-pill flex-fill">Save Changes</button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill flex-fill">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>