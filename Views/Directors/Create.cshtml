@model MoviesCatalog.Models.Director

@{
    ViewData["Title"] = "Add Director";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card border-0 shadow-lg" style="border-radius: 30px;">
                    <div class="card-header bg-transparent border-0 text-center pt-5">
                        <i class="bi bi-person-plus display-1" style="color: #2c3e50;"></i>
                        <h2 class="mt-3 fw-bold">Add New Director</h2>
                    </div>
                    <div class="card-body p-5">
                        <form asp-action="Create">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-bold">Full Name</label>
                                <input asp-for="Name" class="form-control form-control-lg rounded-pill shadow-sm" placeholder="e.g., Christopher Nolan" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Country" class="form-label fw-bold">Country</label>
                                <input asp-for="Country" class="form-control form-control-lg rounded-pill shadow-sm" placeholder="e.g., USA, UK, France" />
                                <span asp-validation-for="Country" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Select Movies by this Director</label>
                                <select name="selectedMovieIds" class="form-select shadow-sm" multiple size="8" style="border-radius: 15px;">
                                    @foreach (var movie in ViewBag.Movies)
                                    {
                                        <option value="@movie.Id">@movie.Title (@movie.ReleaseYear)</option>
                                    }
                                </select>
                                <small class="text-muted">Hold Ctrl (or Cmd on Mac) to select multiple movies</small>
                            </div>

                            <div class="d-flex gap-3 mt-4">
                                <button type="submit" class="btn btn-primary btn-lg rounded-pill flex-fill">Save Director</button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill flex-fill">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>