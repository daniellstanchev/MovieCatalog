@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Panel";
}

<div class="container mt-5">
    <h1 class="display-4 fw-bold mb-4">Admin Panel</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center">
                    <i class="bi bi-people display-1 text-primary"></i>
                    <h3 class="mt-3">Users</h3>
                    <p>Manage registered users</p>
                    <a href="/Admin/Admin/ManageUsers" class="btn btn-primary mt-3">Go →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center">
                    <i class="bi bi-graph-up display-1 text-success"></i>
                    <h3 class="mt-3">Dashboard</h3>
                    <p>View statistics</p>
                    <a href="/Admin/Admin/Dashboard" class="btn btn-success mt-3">Go →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center">
                    <i class="bi bi-film display-1 text-warning"></i>
                    <h3 class="mt-3">Movies</h3>
                    <p>Manage movie catalog</p>
                    <a href="/Movies" class="btn btn-warning mt-3">Go →</a>
                </div>
            </div>
        </div>
    </div>
</div>