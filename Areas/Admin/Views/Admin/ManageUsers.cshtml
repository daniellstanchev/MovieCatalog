@using MoviesCatalog.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Users";
}
@model List<AppUser>

<div class="container mt-5">
    <h1 class="display-4 fw-bold mb-4">Manage Users</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>Email</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = ViewBag.UserRoles[user.Id] as IList<string>;
                        bool isAdmin = roles != null && roles.Contains("Admin");
                        <tr>
                            <td>@user.Email</td>
                            <td>@user.FirstName @user.LastName</td>
                            <td>
                                @if (isAdmin)
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">User</span>
                                }
                            </td>
                            <td>
                                @if (user.Email != "admin@movies.com")
                                {
                                    if (isAdmin)
                                    {
                                        <form asp-action="RemoveAdmin" method="post" style="display:inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-warning">Remove Admin</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="MakeAdmin" method="post" style="display:inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">Make Admin</button>
                                        </form>
                                    }
                                    <form asp-action="DeleteUser" method="post" style="display:inline" onsubmit="return confirm('Delete this user?')">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">Main Admin</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <a href="/Admin" class="btn btn-secondary">← Back to Admin Panel</a>
    </div>
</div>