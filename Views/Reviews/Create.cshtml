@model MoviesCatalog.Models.Review

@{
    ViewData["Title"] = "Add Review";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card border-0 shadow-lg" style="border-radius: 30px;">
                    <div class="card-header bg-transparent border-0 text-center pt-5">
                        <div class="bg-warning rounded-circle d-inline-flex align-items-center justify-content-center p-3 shadow" style="width: 80px; height: 80px;">
                            <i class="bi bi-star-fill display-4 text-white"></i>
                        </div>
                        <h2 class="mt-3 fw-bold">Write a Review</h2>
                        <p class="text-muted">Share your thoughts about a movie</p>
                    </div>
                    <div class="card-body p-5">
                        <form asp-action="Create">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="mb-4">
                                <label asp-for="MovieId" class="form-label fw-bold">Movie</label>
                                <select asp-for="MovieId" class="form-select form-select-lg rounded-pill shadow-sm" asp-items="ViewBag.Movies">
                                    <option value="">Select a movie</option>
                                </select>
                                <span asp-validation-for="MovieId" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Rating" class="form-label fw-bold">Rating (1-10)</label>
                                <div class="d-flex align-items-center gap-3">
                                    <input asp-for="Rating" type="range" class="form-range" min="1" max="10" step="1" id="ratingSlider" style="flex:1;">
                                    <span id="ratingValue" class="badge bg-warning text-dark fs-5 px-3 py-2">5</span>
                                </div>
                                <span asp-validation-for="Rating" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Comment" class="form-label fw-bold">Your Review</label>
                                <textarea asp-for="Comment" class="form-control rounded-4 shadow-sm" rows="5" placeholder="What did you think about the movie?"></textarea>
                                <span asp-validation-for="Comment" class="text-danger"></span>
                            </div>

                            <div class="d-flex gap-3 mt-4">
                                <button type="submit" class="btn btn-danger btn-lg rounded-pill flex-fill">Submit Review</button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill flex-fill">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const slider = document.getElementById('ratingSlider');
    const ratingValue = document.getElementById('ratingValue');
    slider.addEventListener('input', function() {
        ratingValue.textContent = this.value;
    });
</script>