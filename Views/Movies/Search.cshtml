@model X.PagedList.IPagedList<MoviesCatalog.Models.Movie>
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Search Movies";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="display-3 fw-bold mb-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                Search Movies
            </h1>
            <p class="lead text-muted">Find your favorite movies by title or description</p>
        </div>

        <div class="row justify-content-center mb-5">
            <div class="col-md-8">
                <form method="get" asp-action="Search">
                    <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden" style="background: white;">
                        <span class="input-group-text bg-white border-0 ps-4">
                            <i class="bi bi-search" style="color: #667eea;"></i>
                        </span>
                        <input type="text" name="searchTerm" class="form-control border-0 py-3"
                               placeholder="Search by title or description..."
                               value="@ViewBag.SearchTerm"
                               style="outline: none; box-shadow: none;">
                        <button type="submit" class="btn px-4"
                                style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none;">
                            <i class="bi bi-arrow-right me-2"></i>Search
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
        {
            <div class="text-center mb-4">
                <span class="badge bg-primary rounded-pill px-4 py-3 fs-6">
                    <i class="bi bi-film me-2"></i>@Model.TotalItemCount movie@(Model.TotalItemCount != 1 ? "s" : "") found for "@ViewBag.SearchTerm"
                </span>
            </div>
        }

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-0 shadow-lg" style="border-radius: 25px; overflow: hidden; transition: all 0.3s;">
                            <div style="height: 200px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); position: relative;">
                                <div style="position: absolute; bottom: 20px; left: 20px; color: white;">
                                    <h3 class="fw-bold mb-2" style="font-size: 1.5rem;">@item.Title</h3>
                                    <span class="badge bg-danger me-2">@item.ReleaseYear</span>
                                    <span class="badge bg-info">@item.Genre?.Name</span>
                                </div>
                            </div>

                            <div class="card-body p-4">
                                <p class="card-text text-muted mb-4" style="line-height: 1.6;">
                                    @(item.Description?.Length > 120 ? item.Description.Substring(0, 120) + "..." : item.Description ?? "No description available.")
                                </p>

                                @if (item.MovieActors != null && item.MovieActors.Any())
                                {
                                    <div class="mb-4">
                                        <small class="text-uppercase fw-bold text-secondary mb-2 d-block">
                                            <i class="bi bi-people-fill me-1"></i> Cast
                                        </small>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var ma in item.MovieActors.Take(3))
                                            {
                                                <a asp-controller="Actors" asp-action="Details" asp-route-id="@ma.ActorId"
                                                   class="text-decoration-none">
                                                    <span class="badge bg-light text-dark px-3 py-2 rounded-pill border">
                                                        @ma.Actor?.Name
                                                    </span>
                                                </a>
                                            }
                                            @if (item.MovieActors.Count > 3)
                                            {
                                                <span class="badge bg-light text-dark px-3 py-2 rounded-pill border">+@(item.MovieActors.Count - 3)</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="card-footer bg-transparent border-0 p-4 pt-0">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary rounded-pill w-100 py-2"
                                   style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
                                    <i class="bi bi-info-circle me-2"></i>View Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-center mt-5">
                @Html.PagedListPager(Model, page => Url.Action("Search", new { page, searchTerm = ViewBag.SearchTerm }),
                         new PagedListRenderOptions
            {
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" },
                UlElementClasses = new[] { "pagination shadow-sm" }
            })
            </div>
        }
        else if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
        {
            <div class="text-center py-5">
                <i class="bi bi-emoji-frown display-1 text-muted"></i>
                <h3 class="mt-4 text-muted">No movies found</h3>
                <p class="text-muted">Try searching with different keywords</p>
                <a href="/Movies/Search" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="bi bi-arrow-repeat me-2"></i>Clear Search
                </a>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted"></i>
                <h3 class="mt-4 text-muted">Start searching for movies</h3>
                <p class="text-muted">Enter a title or keyword above to find your favorite films</p>
                <div class="d-flex justify-content-center gap-3 mt-3">
                    <span class="badge bg-light text-dark px-3 py-2">🎬 The Matrix</span>
                    <span class="badge bg-light text-dark px-3 py-2">🍿 Inception</span>
                    <span class="badge bg-light text-dark px-3 py-2">⭐ The Dark Knight</span>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
    }

    .input-group:focus-within {
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.3);
        border-radius: 50px;
    }
</style>
