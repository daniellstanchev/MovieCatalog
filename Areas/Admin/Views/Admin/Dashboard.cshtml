@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">
    <h1 class="display-4 fw-bold mb-4">Dashboard</h1>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.TotalMovies</h2>
                    <p>Movies</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.TotalActors</h2>
                    <p>Actors</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.TotalGenres</h2>
                    <p>Genres</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white shadow">
                <div class="card-body text-center">
                    <h2>@ViewBag.TotalUsers</h2>
                    <p>Users</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h4>Recent Movies</h4>
        </div>
        <div class="card-body">
            @if (ViewBag.RecentMovies != null && ViewBag.RecentMovies.Count > 0)
            {
                <ul class="list-group">
                    @foreach (var movie in ViewBag.RecentMovies)
                    {
                        <li class="list-group-item">@movie.Title (@movie.ReleaseYear)</li>
                    }
                </ul>
            }
            else
            {
                <p>No movies yet.</p>
            }
        </div>
    </div>

    <div class="mt-4">
        <a href="/Admin" class="btn btn-secondary">← Back to Admin Panel</a>
    </div>
</div>