@model IEnumerable<MoviesCatalog.Models.Director>

@{
    ViewData["Title"] = "Directors";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-4 fw-bold" style="background: linear-gradient(135deg, #2c3e50, #3498db); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    Directors
                </h1>
                <p class="lead text-muted">Meet the creative minds behind your favorite movies</p>
            </div>
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow">
                <i class="bi bi-plus-circle me-2"></i>Add Director
            </a>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-lg" style="border-radius: 25px; overflow: hidden; transition: transform 0.3s;">
                        <div class="card-header text-white text-center py-4" style="background: linear-gradient(135deg, #2c3e50, #3498db);">
                            <i class="bi bi-person-badge display-1"></i>
                        </div>
                        <div class="card-body text-center p-4">
                            <h3 class="fw-bold mb-3">@item.Name</h3>
                            @if (!string.IsNullOrEmpty(item.Country))
                            {
                                <p class="text-muted">
                                    <i class="bi bi-geo-alt me-2"></i>@item.Country
                                </p>
                            }
                            <div class="mt-3">
                                <span class="badge bg-info rounded-pill px-3 py-2">
                                    <i class="bi bi-film me-1"></i>@(item.Movies?.Count ?? 0) Movies
                                </span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning rounded-pill flex-fill">
                                    <i class="bi bi-pencil me-1"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info rounded-pill flex-fill">
                                    <i class="bi bi-eye me-1"></i> Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-10px);
    }
</style>