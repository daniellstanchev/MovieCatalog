@model MoviesCatalog.Models.Review

@{
    ViewData["Title"] = "Review Details";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card border-0 shadow-lg" style="border-radius: 30px;">
                    <div class="card-header bg-warning text-white text-center py-4 rounded-top-4">
                        <i class="bi bi-chat-quote-fill display-1"></i>
                        <h2 class="mt-2">Review Details</h2>
                    </div>
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h3 class="fw-bold">@Model.Movie?.Title</h3>
                            <p class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i>Reviewed on @Model.CreatedAt.ToShortDateString()
                            </p>
                        </div>

                        <div class="text-center mb-4">
                            <span class="badge bg-warning text-dark rounded-pill px-4 py-3 fs-3">
                                <i class="bi bi-star-fill me-2"></i>@Model.Rating / 10
                            </span>
                        </div>

                        <div class="card bg-light rounded-4 p-4">
                            <p class="lead mb-0" style="font-size: 1.2rem; line-height: 1.8;">
                                "@Model.Comment"
                            </p>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg rounded-pill flex-fill">
                                <i class="bi bi-pencil me-2"></i>Edit
                            </a>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill flex-fill">
                                <i class="bi bi-arrow-left me-2"></i>Back to Reviews
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>