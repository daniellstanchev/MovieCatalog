@model IEnumerable<MoviesCatalog.Models.Review>

@{
    ViewData["Title"] = "Reviews";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-4 fw-bold" style="background: linear-gradient(135deg, #e74c3c, #c0392b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    Movie Reviews
                </h1>
                <p class="lead text-muted">What people are saying about movies</p>
            </div>
            <a asp-action="Create" class="btn btn-danger btn-lg rounded-pill px-5 py-3 shadow">
                <i class="bi bi-star me-2"></i>Add Review
            </a>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-lg" style="border-radius: 25px; transition: transform 0.3s;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1">@item.Movie?.Title</h5>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i>@item.CreatedAt.ToShortDateString()
                                    </small>
                                </div>
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fs-6">
                                    <i class="bi bi-star-fill me-1"></i>@item.Rating/10
                                </span>
                            </div>
                            <p class="card-text mt-3 text-muted" style="line-height: 1.6;">
                                @(item.Comment?.Length > 150 ? item.Comment.Substring(0, 150) + "..." : item.Comment ?? "No comment")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning rounded-pill flex-fill">
                                    <i class="bi bi-pencil me-1"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info rounded-pill flex-fill">
                                    <i class="bi bi-eye me-1"></i> Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-pill flex-fill">
                                    <i class="bi bi-trash me-1"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-10px);
    }
</style>