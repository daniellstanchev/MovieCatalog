@model MoviesCatalog.Models.Review

@{
    ViewData["Title"] = "Delete Review";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card border-0 shadow-lg text-center" style="border-radius: 30px;">
                    <div class="card-body p-5">
                        <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
                        <h2 class="fw-bold mt-3">Delete Review?</h2>
                        <p class="lead text-muted">Are you sure you want to delete this review?</p>

                        <div class="alert alert-light rounded-4 mt-4 text-start">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Movie</dt>
                                <dd class="col-sm-8">@Model.Movie?.Title</dd>
                                <dt class="col-sm-4">Rating</dt>
                                <dd class="col-sm-8">@Model.Rating/10</dd>
                                <dt class="col-sm-4">Comment</dt>
                                <dd class="col-sm-8">@(Model.Comment?.Length > 100 ? Model.Comment.Substring(0, 100) + "..." : Model.Comment ?? "No comment")</dd>
                                <dt class="col-sm-4">Date</dt>
                                <dd class="col-sm-8">@Model.CreatedAt.ToShortDateString()</dd>
                            </dl>
                        </div>

                        <div class="alert alert-warning">
                            <i class="bi bi-info-circle me-2"></i>
                            This action cannot be undone.
                        </div>

                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <div class="d-flex gap-3 mt-4">
                                <button type="submit" class="btn btn-danger btn-lg rounded-pill flex-fill">Yes, Delete</button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill flex-fill">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>